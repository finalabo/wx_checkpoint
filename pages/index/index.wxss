/**index.wxss**/
/** pages/index/index.wxss */
page {
  background-color: #f6f6f6;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.search-box {
  width: 100%;
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 40rpx;
}

.input {
  height: 90rpx;
  background: #f0f2f5;
  border-radius: 10rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  font-size: 32rpx;
}

.btn {
  background-color: #069249;
  color: white;
  font-weight: normal;
}

.btn:active {
  opacity: 0.9;
}

/* 结果卡片 */
.result-card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  animation: fadeIn 0.3s ease;
}

.result-header {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
  border-bottom: 1px solid #eee;
  padding-bottom: 20rpx;
}

.result-item {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
  font-size: 32rpx;
  color: #555;
}

.result-row {
  display: flex;
  justify-content: space-between;
}

.score-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.score-label {
  font-size: 24rpx;
  color: #888;
}

.total .score-num {
  color: #07c160;
  font-size: 48rpx;
}

/* 错误提示 */
.no-result {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-text {
  margin-top: 20rpx;
  color: #888;
  font-size: 30rpx;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* --- 新增：各个题型详细得分的样式 --- */
.details-divider {
  height: 1px;
  background-color: #eee;
  margin: 40rpx 0 30rpx 0;
}

.details-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  text-align: center;
}

.details-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* 一行显示4个题型 */
  gap: 15rpx;
}

.detail-item {
  background-color: #f9f9f9;
  border-radius: 10rpx;
  padding: 15rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-name {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.detail-score {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
}